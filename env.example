# ══════════════════════════════════════════════════════════════════
#  Domain Provisioner – Konfiguration
#  Kopiere diese Datei nach ".env" und fülle alle Felder aus!
# ══════════════════════════════════════════════════════════════════

# ── Paymenter Webhook-Sicherheit ──────────────────────────────────
# Trage hier den Secret ein, den du in Paymenter unter
# Einstellungen > Webhooks > Secret eingestellt hast.
WEBHOOK_SECRET=dein-geheimes-webhook-passwort

# ── Basis-Domain ─────────────────────────────────────────────────
# Deine Hauptdomain – Kunden-Subdomains werden darunter angelegt.
# Beispiel: meinedomain.de → kunde.meinedomain.de
BASE_DOMAIN=meinedomain.de

# ── Cloudflare ───────────────────────────────────────────────────
# API Token: Cloudflare Dashboard → Mein Profil → API-Token
# Benötigte Berechtigung: Zone > DNS > Edit
CF_API_TOKEN=cloudflare_api_token_hier

# Zone-ID: Cloudflare Dashboard → deine Domain → rechts unten
CF_ZONE_ID=cloudflare_zone_id_hier

# True  = Cloudflare Proxy aktiv (orange Wolke, DDoS-Schutz)
# False = Nur DNS (grau, direkter A-Record)
CF_PROXIED=false

# ── Pangolin ─────────────────────────────────────────────────────
# URL deiner Pangolin-Instanz (kein abschließendes /)
PANGOLIN_URL=https://pangolin.meinedomain.de

# API Key: Pangolin Dashboard → Settings → API Keys
PANGOLIN_API_KEY=pangolin_api_key_hier

# Organisation-ID aus Pangolin
PANGOLIN_ORG_ID=1

# Site-ID (optional, leer lassen wenn nicht benötigt)
PANGOLIN_SITE_ID=1

# ── Standard Ziel-Port ───────────────────────────────────────────
# Port auf dem Kundenserver (meist 80 für HTTP, 443 für HTTPS)
DEFAULT_TARGET_PORT=80
